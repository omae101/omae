{
  "name": "lead-sat",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,admin -c blue,magenta \"npm run dev -w @lead-sat/web\" \"npm run dev -w @lead-sat/admin\"",
    "dev:web": "npm run dev -w @lead-sat/web",
    "dev:admin": "npm run dev -w @lead-sat/admin",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @lead-sat/web",
    "build:admin": "npm run build -w @lead-sat/admin",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test -w @lead-sat/shared",
    "db:generate": "npm run db:generate -w @lead-sat/shared",
    "db:migrate": "npm run db:migrate -w @lead-sat/shared",
    "db:studio": "npm run db:studio -w @lead-sat/shared"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "concurrently": "^9.1.0"
  }
}
